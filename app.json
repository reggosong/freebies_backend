{
  "name": "Freebies API",
  "description": "A FastAPI backend for the Freebies app",
  "repository": "https://github.com/yourusername/freebies_app",
  "keywords": ["python", "fastapi", "freebies"],
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL database URL",
      "value": "postgresql://username:password@host:port/database"
    },
    "SECRET_KEY": {
      "description": "Secret key for JWT tokens",
      "generator": "secret"
    },
    "ALGORITHM": {
      "description": "JWT algorithm",
      "value": "HS256"
    },
    "ACCESS_TOKEN_EXPIRE_MINUTES": {
      "description": "JWT token expiration time in minutes",
      "value": "30"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:mini"
    }
  ],
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
